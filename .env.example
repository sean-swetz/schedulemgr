# Local dev: Postgres via Docker (see docker-compose.yml)
DATABASE_URL="postgresql://cfp:cfp@localhost:5433/cfp_coverage?schema=public"

# HTTP server
PORT=3000

# How many weeks ahead to materialize class instances
MATERIALIZE_WEEKS_AHEAD=6

# Base URL used to build magic-link sign-in URLs.
APP_BASE_URL="http://localhost:3000"

# Secret for signing session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change-me"

# Email. When RESEND_API_KEY is unset, magic links are logged to the console.
# RESEND_API_KEY=
MAIL_FROM="CFP Coverage <onboarding@resend.dev>"

# Web push (VAPID). Generate with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"
