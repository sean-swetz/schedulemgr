{
  "name": "cfp-coverage-board",
  "version": "0.1.0",
  "description": "CrossFit Prosperity — coaches-only class coverage board",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ics": "^3.12.0",
    "node-cron": "^4.6.0",
    "resend": "^6.17.2",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "prisma": "^6.2.1"
  }
}
